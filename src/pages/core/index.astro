---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NeuralBackdrop from '../../components/NeuralBackdrop.astro';

const title = 'Synora Core';
const description =
  'Memoria viva del ecosistema Synora: conocimiento, arquitectura, gobernanza y evolución institucional.';

const statusCards = [
  ['Ecossistema', 'Ativo', 'Infraestrutura institucional em evolução'],
  ['Conhecimento', 'Inicial', 'Biblioteca e documentos fundacionais'],
  ['Governança', 'Em estruturação', 'Policies, evidências e auditorias'],
  ['Matilha', 'Operacional', 'Agentes, responsabilidades e evolução']
];

const coreAreas = [
  {
    name: 'Dashboard',
    desc: 'Visão geral do ecossistema, últimas atualizações, próximos marcos e estado dos serviços.',
    items: ['Status dos serviços', 'Últimas atualizações', 'Próximos marcos']
  },
  {
    name: 'Conhecimento',
    desc: 'Biblioteca institucional com documentos fundacionais, manifestos e cartas de valor.',
    items: ['Synora Foundational Architecture', 'Cinco Guardiões da Synora', 'Carta de Valores']
  },
  {
    name: 'Arquitetura',
    desc: 'Documentação técnica e estratégica para decisões, modelos operacionais e diagramas.',
    items: ['ADRs', 'Diagramas', 'Decisões arquiteturais']
  },
  {
    name: 'Evolução',
    desc: 'Linha do tempo da Synora com marcos históricos, roadmaps e decisões estratégicas.',
    items: ['Marcos históricos', 'Programa Nascer', 'Roadmaps']
  },
  {
    name: 'Guardian',
    desc: 'Área dedicada à governança, auditoria, evidências, contratos e compliance.',
    items: ['Policies', 'Contratos', 'Evidências e auditorias']
  },
  {
    name: 'Matilha',
    desc: 'Centro de agentes da Synora com responsabilidades, documentação e histórico evolutivo.',
    items: ['Gugo', 'Skipper', 'Piola', 'Wolf', 'Guardian']
  },
  {
    name: 'Biblioteca',
    desc: 'Repositório central de documentos, apresentações, diagramas, relatórios e estudos.',
    items: ['PDFs', 'Apresentações', 'Materiais de aceleração']
  }
];
---

<BaseLayout title={title} description={description} locale="pt-BR" path="/core">
  <div class="relative min-h-screen overflow-hidden bg-[#071827]">
    <NeuralBackdrop className="nd absolute left-1/2 top-1/2 h-[130%] w-[130%] -translate-x-1/2 -translate-y-1/2" />

    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <nav class="flex items-center justify-between py-5">
        <a class="flex items-center gap-3" href="/">
          <img
            src="/brand/synora-mark.clean.png"
            alt="Synora"
            class="h-10 w-10 rounded-2xl p-1.5 ring-1 ring-white/12"
            loading="eager"
            decoding="async" />
          <div class="text-sm tracking-[0.04em] text-white/85">
            <span class="font-semibold">Synora</span>
            <span class="text-white/45"> Core</span>
          </div>
        </a>
        <div class="flex items-center gap-3">
          <span class="hidden rounded-full bg-cyan-300/10 px-3 py-1 text-xs text-cyan-100 ring-1 ring-cyan-200/20 sm:inline-flex">
            acesso controlado
          </span>
          <a
            href="/"
            class="rounded-full bg-white/5 px-4 py-2 text-sm text-white/70 ring-1 ring-white/10 hover:bg-white/10 hover:text-white">
            Voltar ao site
          </a>
        </div>
      </nav>

      <header class="py-16 md:py-20">
        <div class="max-w-3xl">
          <p class="inline-flex items-center gap-2 rounded-full bg-white/5 px-4 py-2 text-xs text-white/75 ring-1 ring-white/10">
            <span class="h-1.5 w-1.5 rounded-full bg-cyan-300/90"></span>
            Memória viva • Arquitetura • Governança
          </p>
          <h1 class="mt-8 text-5xl font-semibold tracking-tight text-white md:text-7xl">
            Synora Core
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-white/75 md:text-xl">
            O Core preserva o conhecimento, a arquitetura, a governança e a evolução institucional da Synora.
          </p>
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/60">
            Esta primeira versão prepara a estrutura da área restrita. O acesso com autenticação e permissões será
            incorporado na próxima fase.
          </p>
        </div>
      </header>

      <main class="pb-24">
        <section class="grid gap-4 md:grid-cols-4">
          {statusCards.map(([label, value, detail]) => (
            <div class="surface rounded-3xl p-5">
              <p class="text-xs uppercase tracking-[0.18em] text-white/40">{label}</p>
              <p class="mt-3 text-xl font-semibold text-white">{value}</p>
              <p class="mt-2 text-sm leading-relaxed text-white/55">{detail}</p>
            </div>
          ))}
        </section>

        <section class="mt-14 grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
          <div class="surface rounded-[32px] p-8">
            <h2 class="text-2xl font-semibold tracking-tight text-white">Princípio operacional</h2>
            <div class="mt-6 space-y-4 text-sm leading-relaxed text-white/68">
              <p><span class="text-white">As verticais</span> geram valor.</p>
              <p><span class="text-white">O Guardian</span> preserva confiança.</p>
              <p><span class="text-white">O Core</span> preserva conhecimento.</p>
              <p><span class="text-white">O site</span> apresenta a Synora.</p>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {coreAreas.map((area) => (
              <article class="surface glow-hover rounded-3xl p-6">
                <h3 class="text-lg font-semibold text-white">{area.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-white/62">{area.desc}</p>
                <div class="mt-5 h-px bg-gradient-to-r from-white/0 via-white/15 to-white/0"></div>
                <ul class="mt-4 space-y-2 text-xs text-white/50">
                  {area.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>
      </main>
    </div>
  </div>
</BaseLayout>
