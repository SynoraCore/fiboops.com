---
// Ultra-subtle constellation / neural network SVG.
// Keep opacity low; animate only via CSS (cheap).
const { className = '' } = Astro.props as { className?: string };
---

<svg
  class={className}
  viewBox="0 0 1200 700"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="rgba(61,90,254,0.55)" />
      <stop offset="1" stop-color="rgba(0,212,255,0.35)" />
    </linearGradient>
    <radialGradient id="p" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(620 330) rotate(90) scale(420 650)">
      <stop stop-color="rgba(124,77,255,0.22)" />
      <stop offset="1" stop-color="rgba(124,77,255,0)" />
    </radialGradient>
  </defs>

  <!-- soft diffusion blob -->
  <ellipse cx="620" cy="340" rx="520" ry="360" fill="url(#p)" opacity="0.35" />

  <!-- links -->
  <g stroke="url(#g)" stroke-width="1">
    <path class="nd-line" d="M120 120 C 260 40, 360 90, 520 120 C 660 148, 740 80, 910 140" opacity="0.38" />
    <path class="nd-line" d="M180 460 C 340 380, 480 420, 650 420 C 820 420, 900 360, 1050 420" opacity="0.28" />
    <path class="nd-line" d="M520 120 C 540 240, 560 300, 650 420" opacity="0.22" />
    <path class="nd-line" d="M320 240 C 460 260, 520 300, 600 330" opacity="0.18" />
    <path class="nd-line" d="M820 220 C 760 260, 720 300, 650 420" opacity="0.18" />
  </g>

  <!-- nodes -->
  <g>
    {[{ x: 120, y: 120 }, { x: 320, y: 240 }, { x: 520, y: 120 }, { x: 650, y: 420 }, { x: 910, y: 140 }, { x: 1050, y: 420 }, { x: 820, y: 220 }, { x: 600, y: 330 }].map((n) => (
      <g>
        <circle cx={n.x} cy={n.y} r="2" fill="rgba(245,247,251,0.55)" />
        <circle cx={n.x} cy={n.y} r="10" fill="rgba(0,212,255,0.08)" />
      </g>
    ))}
  </g>
</svg>

